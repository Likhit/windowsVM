<domain type="kvm">
  <name>win11</name>
  <metadata>
    <windowsVM:managed xmlns:windowsVM="https://github.com/windowsVM">true</windowsVM:managed>
  </metadata>

  <memory unit="MiB">@memory@</memory>
  <currentMemory unit="MiB">@memory@</currentMemory>
  <vcpu placement="static">@vcpus@</vcpu>

  <os>
    <type arch="x86_64" machine="pc-q35-9.2">hvm</type>
    <loader readonly="yes" secure="yes" type="pflash">@ovmfCode@</loader>
    <nvram template="@ovmfVars@">/var/lib/libvirt/qemu/nvram/win11_VARS.fd</nvram>
    <boot dev="hd"/>
    <boot dev="cdrom"/>
  </os>

  <features>
    <acpi/>
    <apic/>
    <hyperv mode="custom">
      <relaxed state="on"/>
      <vapic state="on"/>
      <spinlocks state="on" retries="8191"/>
      <vpindex state="on"/>
      <runtime state="on"/>
      <synic state="on"/>
      <stimer state="on"/>
      <reset state="on"/>
      <vendor_id state="on" value="AuthenticAMD"/>
      <frequencies state="on"/>
      <tlbflush state="on"/>
      <ipi state="on"/>
    </hyperv>
    <kvm>
      <hidden state="on"/>
    </kvm>
    <vmport state="off"/>
    <smm state="on"/>
  </features>

  <cpu mode="host-passthrough" check="none" migratable="off">
    <topology sockets="1" dies="1" cores="@vcpus@" threads="1"/>
    <feature policy="require" name="topoext"/>
  </cpu>

  <clock offset="localtime">
    <timer name="rtc" tickpolicy="catchup"/>
    <timer name="pit" tickpolicy="delay"/>
    <timer name="hpet" present="no"/>
    <timer name="hypervclock" present="yes"/>
    <timer name="tsc" present="yes" mode="native"/>
  </clock>

  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <pm>
    <suspend-to-mem enabled="no"/>
    <suspend-to-disk enabled="no"/>
  </pm>

  <devices>
    <emulator>@qemuBin@</emulator>

    <!-- System disk (qcow2, thin-provisioned) -->
    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2" discard="unmap"/>
      <source file="/var/lib/libvirt/images/win11.qcow2"/>
      <target dev="vda" bus="virtio"/>
    </disk>

    <!-- Windows ISO -->
    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="@isoPath@"/>
      <target dev="sda" bus="sata"/>
      <readonly/>
    </disk>

    <!-- VirtIO driver ISO -->
    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="@virtioIso@"/>
      <target dev="sdb" bus="sata"/>
      <readonly/>
    </disk>

    <!-- VirtIO NIC on default NAT -->
    <interface type="network">
      <source network="default"/>
      <model type="virtio"/>
    </interface>

    <!-- TPM 2.0 (swtpm) -->
    <tpm model="tpm-crb">
      <backend type="emulator" version="2.0"/>
    </tpm>

    <!-- Input devices -->
    <input type="tablet" bus="usb"/>
    <input type="keyboard" bus="virtio"/>
    <input type="mouse" bus="virtio"/>

    <!-- Graphics (temporary SPICE for install, replaced by Looking Glass later) -->
    <graphics type="spice" autoport="yes">
      <listen type="address" address="127.0.0.1"/>
    </graphics>
    <video>
      <model type="qxl" ram="65536" vram="65536" vgamem="16384" heads="1" primary="yes"/>
    </video>

    <!-- USB controllers -->
    <controller type="usb" model="qemu-xhci" ports="15"/>

    <!-- Serial console for debugging -->
    <serial type="pty">
      <target type="isa-serial" port="0"/>
    </serial>
    <console type="pty">
      <target type="serial" port="0"/>
    </console>

    @gpuConfig@

    @gpuAudioConfig@

    <!-- Channel for QEMU guest agent -->
    <channel type="unix">
      <target type="virtio" name="org.qemu.guest_agent.0"/>
    </channel>

    @usbDevicesConfig@

    @shmemConfig@
  </devices>
</domain>
